# ===== Test Environment Configuration Template =====
# Copy this file to .env.test for local testing, or export these variables in your CI environment.
# DO NOT use these values in production. All values here are placeholders for testing only.
#
# Quick setup:
#   cp .env.test.example .env.test
#   # Then run tests with:
#   env $(cat .env.test | xargs) python -m pytest tests/unit/
#
# Or export individually:
#   export SECRET_KEY=test-secret-key-not-for-production-use-only
#   export DATABASE_URL=sqlite+aiosqlite:///:memory:
#   export JWT_SECRET_KEY=test-jwt-secret-key-not-for-production-use-only
#   export ENCRYPTION_KEY=IzvzCpOZnvW2JJ8NwAt2plTTRdIalbD0-M0pucyCJ-w=

APP_NAME=TradeDesk-Test
APP_ENV=development
DEBUG=True

# ─── Minimum required settings (test-safe placeholder values) ───────────────

# Generate your own with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=test-secret-key-not-for-production-use-only

DATABASE_URL=sqlite+aiosqlite:///:memory:

# Generate your own with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=test-jwt-secret-key-not-for-production-use-only

# Generate your own with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=IzvzCpOZnvW2JJ8NwAt2plTTRdIalbD0-M0pucyCJ-w=

# ─── Test database (override to in-memory) ───────────────────────────────────

TEST_DATABASE_URL=sqlite+aiosqlite:///:memory:
TEST_SYNC_DATABASE_URL=sqlite:///:memory:
