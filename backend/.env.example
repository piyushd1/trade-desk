# ===== TradeDesk Backend Environment Configuration =====
# Copy this file to .env and fill in your actual values
# Run: python scripts/setup_env.py (or manually copy and edit)

# ===== Application Settings =====
APP_NAME=TradeDesk
APP_ENV=development  # Options: development, staging, production
DEBUG=True  # Set to False in production
SECRET_KEY=your-secret-key-here-change-this-in-production
APP_DOMAIN=example.com  # Your domain name (e.g., yourdomain.com)
APP_URL=http://localhost:8000  # Full application URL
API_BASE_URL=http://localhost:8000  # Backend API base URL
FRONTEND_URL=http://localhost:3000  # Frontend application URL

# ===== Server Configuration =====
API_HOST=0.0.0.0
API_PORT=8000
WORKERS=4

# ===== Database Configuration =====
# For SQLite (development):
DATABASE_URL=sqlite+aiosqlite:///./tradedesk.db
# For PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/tradedesk
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=0

# ===== Redis Configuration =====
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# ===== Celery Configuration =====
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ===== JWT Authentication =====
JWT_SECRET_KEY=your-jwt-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ===== Data Encryption =====
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-key-here-generate-with-command-above

# ===== SEBI Compliance Settings =====
STATIC_IP=0.0.0.0  # Your static IP address for SEBI compliance
OPS_LIMIT=10
MAX_DAILY_TRADES=50

# ===== Zerodha Broker Integration =====
ZERODHA_API_KEY=your-zerodha-api-key
ZERODHA_API_SECRET=your-zerodha-api-secret
ZERODHA_REDIRECT_URL=http://localhost:8000/api/v1/auth/zerodha/callback
ZERODHA_AUTO_REFRESH_ENABLED=True
ZERODHA_REFRESH_INTERVAL_MINUTES=15
ZERODHA_REFRESH_EXPIRY_BUFFER_MINUTES=60
ZERODHA_USER_IDENTIFIER=YOUR_USER_ID  # Your Zerodha user ID

# ===== IndStocks (IndMoney) Broker Integration (Optional) =====
# IndStocks uses a static bearer token, not OAuth. Generate yours at
# web.indstocks.com → API section → "Get Started". The token expires every
# 24 hours and has no programmatic refresh — paste a fresh token daily.
# Do NOT include a "Bearer " prefix; IndStocks uses the raw token.
# INDSTOCKS_ACCESS_TOKEN=your-indstocks-token-paste-from-web-ui
# INDSTOCKS_USER_IDENTIFIER=YOUR_INDMONEY_USER_ID  # Default routing identifier for broker_sessions

# ===== Groww Broker Integration (Optional) =====
# GROWW_API_KEY=your-groww-api-key
# GROWW_API_SECRET=your-groww-api-secret
# GROWW_TOTP_SECRET=your-groww-totp-secret

# ===== Yahoo Finance / Fundamentals Configuration =====
YFINANCE_CACHE_ENABLED=True
YFINANCE_CACHE_TTL_HOURS=24
YFINANCE_RATE_LIMIT_PER_SECOND=0.9
FUNDAMENTALS_UPDATE_THRESHOLD_HOURS=24

# ===== Risk Management Parameters =====
MAX_POSITION_VALUE=50000.0
MAX_DAILY_LOSS=5000.0
MAX_POSITIONS=5
MAX_DRAWDOWN_PCT=15.0
DEFAULT_STOP_LOSS_PCT=2.0
DEFAULT_TARGET_PROFIT_PCT=4.0

# ===== Monitoring Configuration =====
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001

# ===== Logging Configuration =====
LOG_LEVEL=INFO  # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE=/var/log/tradedesk/app.log

# ===== Default Admin User Configuration (Optional) =====
# These are used during initial setup only
# Leave empty to be prompted during first-time setup
ADMIN_USERNAME=
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ===== Test Environment Configuration (Optional) =====
# Used for testing only - can be different from production credentials
TEST_DATABASE_URL=sqlite+aiosqlite:///:memory:
TEST_SYNC_DATABASE_URL=sqlite:///:memory:
TEST_USER_USERNAME=testuser
TEST_USER_PASSWORD=testpass123
TEST_ADMIN_USERNAME=admin
TEST_ADMIN_PASSWORD=admin123
