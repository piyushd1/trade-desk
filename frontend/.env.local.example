# ===== TradeDesk Frontend Environment Configuration =====
# Copy this file to .env.local and fill in your actual values
# Run: npm run setup (or manually copy and edit)

# ===== API Configuration =====
# Backend API URL - must be prefixed with NEXT_PUBLIC_ to be available in browser
# Development: http://localhost:8000/api/v1
# Production: https://yourdomain.com/api/v1 or https://api.yourdomain.com/v1
NEXT_PUBLIC_API_URL=/api/v1

# ===== Application Configuration =====
# These can be used for analytics, feature flags, etc.
# NEXT_PUBLIC_APP_NAME=TradeDesk
# NEXT_PUBLIC_APP_ENV=development

# ===== Optional: Analytics & Monitoring =====
# NEXT_PUBLIC_GA_ID=your-google-analytics-id
# NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn
